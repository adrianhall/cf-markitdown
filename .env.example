# CloudFlare Workers Environment Variables
# Copy this file to .env and fill in your values

# JWT Signing Key (optional - if not set, JWT auth is disabled)
# Generate with: openssl rand -base64 32
JWT_SIGNING_KEY=your-jwt-signing-key-here

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# CloudFlare Account ID and API token - use these if you want to enable automatic deployment from GitHub Actions
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token

# KV Namespace IDs
KV_NAMESPACE_ID=your-kv-namespace-id
KV_PREVIEW_ID=your-preview-kv-namespace-id
KV_PROD_ID=your-production-kv-namespace-id
KV_DEV_ID=your-dev-kv-namespace-id
