# Auto detect text files and perform LF normalization
* text=auto

# TypeScript/JavaScript files
text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf

# Executable scripts
*.sh text eol=lf
*.zsh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.doc binary
*.odt binary

# Lock files
package-lock.json text eol=lf -diff
yarn.lock text eol=lf -diff
pnpm-lock.yaml text eol=lf -diff
