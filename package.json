{
  "name": "cf-markitdown",
  "version": "1.0.0",
  "description": "CloudFlare Workers service for converting DOCX, ODT, and PDF files to Markdown",
  "main": "src/index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianhall/cf-markitdown"
  },
  "author": "Adrian Hall",
  "license": "MIT",
  "keywords": [
    "cloudflare",
    "workers",
    "markdown",
    "conversion",
    "docx",
    "pdf"
  ],
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy src/index.ts",
    "build": "wrangler build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage || exit 0",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "quality-gate": "run-s typecheck lint build test:coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.0",
    "@cloudflare/workers-types": "^4.20260401.1",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-istanbul": "4.1.2",
    "eslint": "9.39.4",
    "eslint-config-typescript": "^3.0.0",
    "globals": "15.13.0",
    "npm-run-all": "4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.0",
    "vitest": "4.1.2",
    "wrangler": "^4.77.0"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "jose": "6.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "directories": {
    "test": "tests"
  }
}
