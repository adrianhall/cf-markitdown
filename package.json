{
  "name": "cf-markitdown",
  "version": "1.0.0",
  "description": "CloudFlare Workers service for converting DOCX, ODT, and PDF files to Markdown",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianhall/cf-markitdown"
  },
  "author": "Adrian Hall",
  "license": "MIT",
  "keywords": [
    "cloudflare",
    "workers",
    "markdown",
    "conversion",
    "docx",
    "pdf"
  ],
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy src/index.ts",
    "build": "wrangler build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-typescript": "^3.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "vitest-environment-miniflare": "2.14.4",
    "wrangler": "^3.25.0"
  },
  "dependencies": {
    "hono": "^3.12.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "directories": {
    "test": "tests"
  }
}
